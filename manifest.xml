<?xml version="1.0" encoding="UTF-8"?>

<manifest>

  <!-- Remotes -->
  <remote name="moldemort"
          fetch="https://github.com/moldemort" />
  <remote name="munch-devs"
          fetch="https://codeberg.org/munch-devs" />
  <remote name="PocoF3Releases"
          fetch="https://github.com/PocoF3Releases" />
<remote name="kvsnr113"
          fetch="https://github.com/kvsnr113" />

  <!-- Device Tree -->
  <project
      path="device/xiaomi/munch"
      name="android_device_xiaomi_munch"
      remote="moldemort"
      revision="mist" />

  <!-- Vendor Tree -->
  <project
      path="vendor/xiaomi/munch"
      name="android_vendor_xiaomi_munch"
      remote="moldemort"
      revision="16-qpr2" />

  <!-- Firmware -->
  <project
      path="vendor/xiaomi/munch-firmware"
      name="android_vendor_xiaomi_munch-firmware"
      remote="munch-devs"
      revision="vic" />

  <!-- Kernel -->
  <project
      path="kernel/xiaomi/munch"
      name="xiaomi_sm8250_kernel"
      remote="kvsnr113"
      revision="main-bpf" />

  <!-- Hardware Xiaomi -->
  <project
      path="hardware/xiaomi"
      name="android_hardware_xiaomi"
      remote="moldemort"
      revision="lineage-23.2" />

  <!-- Dolby -->
  <project
      path="hardware/dolby"
      name="android_hardware_dolby"
      remote="moldemort"
      revision="main" />

  <!-- Device Settings -->
  <remove-project path="packages/resources/devicesettings" />
  <project
      path="packages/resources/devicesettings"
      name="packages_resources_devicesettings"
      remote="PocoF3Releases"
      revision="aosp-16" />

  <!-- MiuiCamera -->
  <project
      path="hardware/xiaomi/miuicamera"
      name="android_vendor_xiaomi_miuicamera"
      remote="munch-devs"
      revision="vic" />

</manifest>
