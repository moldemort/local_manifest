<?xml version="1.0" encoding="UTF-8"?>

<manifest>
    <!-- Remotes -->
    <remote name="moldemort"   fetch="https://github.com/moldemort" />
    <remote name="munch-devs" fetch="https://codeberg.org/munch-devs" />

    <!-- Device Tree -->
    <project
        path="device/xiaomi/munch"
        name="android_device_xiaomi_munch"
        remote="moldemort"
        revision="mist" />

    <!-- Vendor Tree -->
    <project
        path="vendor/xiaomi/munch"
        name="android_vendor_xiaomi_munch"
        remote="moldemort"
        revision="mist" />

    <!-- MiuiCamera -->
    <project
        path="hardware/xiaomi/miuicamera"
        name="android_vendor_xiaomi_miuicamera"
        remote="munch-devs"
        revision="main" />

    <!-- Dolby -->
    <project
        path="hardware/dolby"
        name="android_hardware_dolby"
        remote="moldemort"
        revision="main" />

</manifest>
